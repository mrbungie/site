---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { getTranslations, getLangFromUrl, type Locale } from '../i18n/utils';
import { routePath } from '../i18n/routes';

interface Props {
	lang?: Locale;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;
const t = getTranslations(lang);
---

<header class="sticky top-0 z-50 w-full border-b border-teal-100/80 bg-white/80 backdrop-blur-md supports-[backdrop-filter]:bg-white/70">
	<nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
		<div class="flex items-center gap-8">
			<a href={lang === 'es' ? '/' : `/${lang}/`} class="text-xl font-black tracking-tighter text-slate-900 hover:text-teal-700 transition-colors">
				{SITE_TITLE}
			</a>
			
			<div class="hidden md:flex items-center gap-1">
				<HeaderLink href={lang === 'es' ? '/' : `/${lang}/`} class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 rounded-lg transition-colors">
					{t('nav.home')}
				</HeaderLink>
				<HeaderLink href={routePath(lang, 'concepts')} class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 rounded-lg transition-colors">
					{t('nav.concepts')}
				</HeaderLink>
				<HeaderLink href={routePath(lang, 'blog')} class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 rounded-lg transition-colors">
					{t('nav.blog')}
				</HeaderLink>
				<HeaderLink href={routePath(lang, 'about')} class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 rounded-lg transition-colors">
					{t('nav.about')}
				</HeaderLink>
			</div>
		</div>

		<div class="flex items-center gap-4">
			<div class="flex items-center gap-2 rounded-xl bg-teal-50/80 p-1 ring-1 ring-teal-100">
				{['es', 'en'].map((l) => (
					<a 
						href={l === 'es' ? '/' : `/${l}/`}
						class:list={[
							'px-3 py-1 text-xs font-bold rounded-lg transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white',
							lang === l ? 'bg-white text-teal-700 shadow-sm ring-1 ring-teal-100' : 'text-slate-500 hover:text-slate-900'
						]}
					>
						{l.toUpperCase()}
					</a>
				))}
			</div>
			
			<a href="https://github.com/withastro/astro" target="_blank" class="text-slate-400 hover:text-teal-700 transition-colors p-2">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>
