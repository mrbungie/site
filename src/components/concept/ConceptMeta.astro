---
import { getLevelTranslationKey, getTranslations, localePath, type Level, type Locale } from '../../i18n/utils';
import Badge from '../ui/Badge.astro';

interface Props {
	level: Level;
	area: string;
	prerequisites?: string[];
	related?: string[];
	lang: Locale;
}

const { level, area, prerequisites = [], related = [], lang } = Astro.props;
const t = getTranslations(lang);
---

<div class="flex flex-col gap-6 p-6 rounded-2xl border border-slate-200 bg-slate-50">
	<div class="flex flex-col gap-2">
		<h4 class="text-xs font-bold uppercase tracking-wider text-slate-500">{t('concepts.level')}</h4>
		<Badge variant="accent" class="w-fit">{t(getLevelTranslationKey(level))}</Badge>
	</div>
	
	<div class="flex flex-col gap-2">
		<h4 class="text-xs font-bold uppercase tracking-wider text-slate-500">{t('concepts.area')}</h4>
		<span class="text-sm font-semibold text-slate-700 uppercase tracking-widest">{area}</span>
	</div>

	{prerequisites.length > 0 && (
		<div class="flex flex-col gap-3">
			<h4 class="text-xs font-bold uppercase tracking-wider text-slate-500">{t('concepts.prerequisites')}</h4>
			<ul class="flex flex-col gap-2">
				{prerequisites.map((p) => (
					<li>
						<a href={localePath(lang, `/conceptos/${p}`)} class="text-sm text-teal-700 hover:underline">
							{p.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
						</a>
					</li>
				))}
			</ul>
		</div>
	)}

	{related.length > 0 && (
		<div class="flex flex-col gap-3">
			<h4 class="text-xs font-bold uppercase tracking-wider text-slate-500">{t('concepts.related')}</h4>
			<ul class="flex flex-col gap-2">
				{related.map((r) => (
					<li>
						<a href={localePath(lang, `/conceptos/${r}`)} class="text-sm text-teal-700 hover:underline">
							{r.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
						</a>
					</li>
				))}
			</ul>
		</div>
	)}
</div>
