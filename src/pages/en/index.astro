---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import ConceptCard from '../../components/concept/ConceptCard.astro';
import Card from '../../components/ui/Card.astro';
import { useTranslations } from '../../i18n/utils';
import { routePath } from '../../i18n/routes';

const lang = 'en'; // Force English
const t = useTranslations(lang);

const featuredConcepts = (await getCollection('concepts'))
	.filter(c => c.id.startsWith(`${lang}/`) && c.data.featured && !c.data.draft)
	.slice(0, 3);

// Blog posts are usually common but we can filter by language if needed
const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<BaseLayout title={t('site.title')} description={t('site.description')} lang={lang}>
	<div class="flex flex-col gap-24 py-12">
		<!-- Hero Section -->
		<section class="flex flex-col gap-6 text-center md:text-left py-12">
			<h1 class="text-5xl font-extrabold tracking-tight text-slate-950 sm:text-7xl lg:text-8xl">
				{t('home.hero.title')}
			</h1>
			<p class="text-2xl text-slate-600 leading-relaxed max-w-4xl mx-auto md:mx-0">
				{t('home.hero.subtitle')}
			</p>
		</section>

		<!-- Featured Concepts -->
		<section class="flex flex-col">
			<SectionHeader 
				title={t('home.featured')} 
				href={routePath(lang, 'concepts')} 
				linkText="Explore concepts"
			/>
			{featuredConcepts.length > 0 ? (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{featuredConcepts.map((concept) => (
						<ConceptCard 
							title={concept.data.title}
							summary={concept.data.summary}
							href={routePath(lang, 'concepts', concept.id.split('/')[1].replace(/\.(mdx|md)$/, ''))}
							level={concept.data.level}
							area={concept.data.area}
							lang={lang}
						/>
					))}
				</div>
			) : (
				<div class="p-12 rounded-2xl border-2 border-dashed border-slate-200 text-center">
					<p class="text-slate-500 font-medium italic">English concepts coming soon...</p>
				</div>
			)}
		</section>

		<!-- Latest Blog Posts -->
		<section class="flex flex-col">
			<SectionHeader 
				title="Latest posts" 
				href={routePath(lang, 'blog')} 
			/>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{latestPosts.map((post) => (
					<Card 
						title={post.data.title}
						description={post.data.description}
						href={`/blog/${post.id}/`}
						tags={post.data.tags}
						image={post.data.heroImage?.src}
					/>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
